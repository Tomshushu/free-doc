              size="small"
            >
              {{ row.type === 'OWNER' ? '拥有者' : '参与者' }}
            </el-tag>
          </template>
        </el-table-column>
        <el-table-column label="权限" width="100">
          <template #default="{ row }">
            <el-select :model-value="row.permission || (row.type === 'OWNER' ? 'rw' : 'r')" size="small" disabled class="!w-full">
              <el-option label="只读" value="r" />
              <el-option label="读写" value="rw" />
            </el-select>
          </template>
        </el-table-column>
        <el-table-column label="操作" width="70" align="center">
          <template #default="{ row }">
            <el-button text type="danger" size="small" :disabled="row.type === 'OWNER'" @click="handleRemoveMember(row)">删除</el-button>
