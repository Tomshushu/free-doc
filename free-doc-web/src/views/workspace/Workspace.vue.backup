          </div>
          <el-form-item label="角色" class="!mb-0 !mr-0">
            <el-select v-model="addMemberForm.type" style="width: 130px">
              <el-option label="管理员(OWNER)" value="OWNER" />
              <el-option label="参与者(PARTICIPANT)" value="PARTICIPANT" />
            </el-select>
          </el-form-item>
          <el-form-item label="权限" class="!mb-0 !mr-0">
            <el-select v-model="addMemberForm.permission" style="width: 90px">
              <el-option label="读写" value="rw" />
              <el-option label="只读" value="r" />
            </el-select>
          </el-form-item>
        </div>

        <div class="mt-3 flex justify-end gap-2">
          <el-button type="primary" :disabled="!addMemberForm.userId" @click="submitAddMember">确认添加</el-button>
          <el-button @click="cancelAddMember">取消</el-button>
        </div>
      </div>
