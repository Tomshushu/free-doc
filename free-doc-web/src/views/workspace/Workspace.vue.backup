    <!-- 新建用户弹窗 -->
    <el-dialog v-model="showCreateUserDialog" title="新建用户" width="460px" destroy-on-close>
      <el-form :model="userForm" label-width="80px">
        <el-form-item label="账号" required>
          <el-input v-model="userForm.account" placeholder="请输入登录账号" maxlength="30" />
        </el-form-item>
        <el-form-item label="密码" required>
          <el-input v-model="userForm.password" type="password" placeholder="请输入密码" show-password maxlength="32" />
        </el-form-item>
        <el-form-item label="用户名">
          <el-input v-model="userForm.userName" placeholder="请输入显示名称（可选）" maxlength="20" />
